{
  "name": "bhuwana-id-portal",
  "version": "1.0.0",
  "description": "Lang Lang Bhuwana - Institutional Portal Website",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:public": "next dev",
    "dev:admin": "npm --prefix admin-dashboard run dev",
    "clean": "rm -rf node_modules .next out admin-dashboard/.next admin-dashboard/node_modules",
    "build": "next build",
    "build:public": "next build",
    "build:admin": "npm --prefix admin-dashboard run build",
    "smoke:quick": "node scripts/smoke.mjs",
    "smoke": "npm run smoke:quick && npm run build:public && npm run build:admin",
    "start": "next start",
    "start:public": "next start",
    "start:admin": "npm --prefix admin-dashboard run start",
    "lint": "next lint"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "lucide-react": "^0.263.1"
  },
  "devDependencies": {
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16",
    "@tailwindcss/typography": "^0.5.10",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.0.0"
  }
}
